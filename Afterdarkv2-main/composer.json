{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/vue-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "aerni/laravel-spotify": "*",
        "anhskohbo/no-captcha": "^3.7.0",
        "ashallendesign/laravel-exchange-rates": "^7.9",
        "elegantweb/sanitizer": "^2.3",
        "graham-campbell/throttle": "^11.0",
        "guzzlehttp/guzzle": "^7.9",
        "inertiajs/inertia-laravel": "^2.0",
        "intervention/image": "^3.11",
        "intervention/image-laravel": "^1.5",
        "james-heinrich/getid3": "^1.9",
        "laravel/framework": "^12.0",
        "laravel/helpers": "^1.7",
        "laravel/horizon": "^5.33",
        "laravel/passport": "^12.0",
        "laravel/scout": "^10.14",
        "laravel/socialite": "^5.18",
        "laravel/tinker": "^2.10.1",
        "laravel/ui": "^4.6",
        "league/flysystem-aws-s3-v3": "^3.0",
        "lucasdotvin/laravel-soulbscription": "^4.3",
        "mews/purifier": "^3.4",
        "nnjeim/world": "^1.1",
        "orangehill/iseed": "^3.1",
        "pbmedia/laravel-ffmpeg": "^8.7",
        "socialiteproviders/manager": "^4.8",
        "socialiteproviders/reddit": "^4.1",
        "socialiteproviders/spotify": "^4.1",
        "spatie/laravel-analytics": "^5.5",
        "spatie/laravel-backup": "^9.2",
        "spatie/laravel-feed": "^4.4",
        "spatie/laravel-medialibrary": "*",
        "spatie/laravel-newsletter": "^5.3",
        "spatie/laravel-permission": "^6.17",
        "spatie/laravel-settings": "^3.6",
        "spatie/laravel-sitemap": "^7.3",
        "srmklive/paypal": "^3.0",
        "stripe/stripe-php": "^16.6",
        "symfony/http-client": "^7.3",
        "symfony/mailgun-mailer": "^7.3",
        "tightenco/ziggy": "^2.4",
        "torann/laravel-meta-tags": "^3.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.15",
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "*",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "dev:ssr": [
            "npm run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr"
        ],
        "pint": [
            "./vendor/bin/pint"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
